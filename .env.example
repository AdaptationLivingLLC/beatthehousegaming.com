# Beat The House Gaming — environment variables
# Copy this to .env.local for local development, or set these in the Vercel dashboard
# for production/preview deployments. NEVER commit a real .env file.

# ─── Database (Neon Postgres) ─────────────────────────────────────────────
# Create a free project at neon.tech, grab the pooled connection string.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/bthg?sslmode=require"

# ─── Email (Resend) ───────────────────────────────────────────────────────
# Sign up at resend.com, verify beatthehousegaming.com domain, create an API key.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="Roulette Breaker <no-reply@beatthehousegaming.com>"
RESEND_REPLY_TO="brandon@beatthehousegaming.com"

# ─── Stripe (Payments) ────────────────────────────────────────────────────
# Dashboard → Developers → API keys (use the RESTRICTED secret key, not the full secret)
# scopes: checkout_session:read, customer:read, webhook signature verification
STRIPE_SECRET_KEY="your_stripe_restricted_key_here"
# Dashboard → Developers → Webhooks → add endpoint pointing to /api/stripe-webhook,
# copy the Signing secret (starts with whsec_)
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Access-key HMAC signing ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used server-side ONLY to sign and verify access keys. Rotate if ever leaked.
BTHG_HMAC_SECRET="change-me-64-hex-chars-generate-fresh-never-commit-the-real-value"

# ─── JWT session signing ──────────────────────────────────────────────────
# Separate secret for JWT session tokens. Generate same way as BTHG_HMAC_SECRET.
BTHG_JWT_SECRET="change-me-64-hex-chars-generate-fresh-never-commit-the-real-value"

# ─── Admin authentication ────────────────────────────────────────────────
# Scrypt hash of the admin password. Generate with scripts/hash-password.mjs
# Format: scrypt$N$r$p$salt_hex$derived_key_hex
BTHG_ADMIN_PASSWORD_HASH="scrypt$16384$8$1$salt_here$derived_key_here"

# ─── Contact form / lead capture ──────────────────────────────────────────
# Optional Slack webhook for real-time lead alerts
SLACK_LEAD_WEBHOOK_URL=""

# ─── Public config (safe to expose) ───────────────────────────────────────
# These are NEXT_PUBLIC_* equivalents — they can appear in client bundles.
PUBLIC_SITE_URL="https://beatthehousegaming.com"
PUBLIC_STRIPE_BUY_URL="https://buy.stripe.com/8x28wP69u1e97a5de69MY08"
